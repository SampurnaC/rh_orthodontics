<section class="py-5 bg-light">
  <div class="container">

    <div class="row align-items-center">

      <div class="col-md-6">

        <h1 class="display-5 fw-bold text-dark">
          Premium Dental Care You Can Trust
        </h1>

        <p class="lead text-secondary mt-3">
          Invisalign, braces, whitening & cosmetic dentistry with expert precision and comfort.
        </p>

        <div class="mt-4">

          <a class="btn btn-warning btn-lg fw-bold me-2">
            Book Appoinment
          </a>

          <a class="btn btn-outline-dark btn-lg">
            Learn More
          </a>

        </div>

        <p class="text-muted small mt-3">
          ✔ Private Clinic · ✔ Expert Dentists · ✔ Modern Technology
        </p>

      </div>

      <div class="col-md-6 text-center">

        <img src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95"
             class="img-fluid rounded shadow"
             alt="Dental clinic">

      </div>

    </div>

  </div>
</section>

<section id="treatments" class="py-5 bg-white">

  <div class="container text-center">

    <h2 class="fw-bold mb-5">Our Treatments</h2>

    <div class="row g-4">

      <div class="col-md-4">
        <div class="card border-dark shadow-sm h-100">

          <div class="card-body">

            <h5 class="fw-bold text-dark">Invisalign</h5>
            <p class="text-secondary">Clear aligners for discreet teeth straightening.</p>

          </div>

        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-dark shadow-sm h-100">

          <div class="card-body">

            <h5 class="fw-bold text-dark">Braces</h5>
            <p class="text-secondary">Fixed orthodontic treatment for all ages.</p>

          </div>

        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-dark shadow-sm h-100">

          <div class="card-body">

            <h5 class="fw-bold text-dark">Whitening</h5>
            <p class="text-secondary">Professional teeth whitening for a brighter smile.</p>

          </div>

        </div>
      </div>

    </div>

  </div>

</section>

<section id="why" class="py-5 bg-dark text-white">

  <div class="container text-center">

    <h2 class="fw-bold text-warning mb-4">Why Choose Us</h2>

    <div class="row g-4">

      <div class="col-md-4">
        <h5>Expert Dentists</h5>
        <p class="text-light">Highly trained specialists with years of experience.</p>
      </div>

      <div class="col-md-4">
        <h5>Modern Technology</h5>
        <p class="text-light">Advanced equipment for precise treatment.</p>
      </div>

      <div class="col-md-4">
        <h5>Transparent Pricing</h5>
        <p class="text-light">No hidden costs, fully honest care.</p>
      </div>

    </div>

  </div>

</section>

<section id="team" class="py-5 bg-light">

  <div class="container text-center">

    <h2 class="fw-bold mb-5">Our Team</h2>

    <div class="row g-4">

      <div class="col-md-4">
        <div class="card border-dark shadow-sm">

          <div class="card-body">

            <h5 class="fw-bold">Dr. Smith</h5>
            <p class="text-warning">Orthodontist</p>

          </div>

        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-dark shadow-sm">

          <div class="card-body">

            <h5 class="fw-bold">Dr. John</h5>
            <p class="text-warning">Cosmetic Dentist</p>

          </div>

        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-dark shadow-sm">

          <div class="card-body">

            <h5 class="fw-bold">Sarah</h5>
            <p class="text-warning">Clinic Manager</p>

          </div>

        </div>
      </div>

    </div>

  </div>

</section>

<section id="reviews" class="py-5 bg-white">

  <div class="container text-center">

    <h2 class="fw-bold mb-5">Patient Reviews</h2>

    <div class="row g-4">

      <div class="col-md-4">
        <div class="card border-dark shadow-sm">

          <div class="card-body">

            <p class="text-secondary">"Amazing professional service."</p>
            <strong class="text-warning">- Patient</strong>

          </div>

        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-dark shadow-sm">

          <div class="card-body">

            <p class="text-secondary">"Best dental clinic experience."</p>
            <strong class="text-warning">- Patient</strong>

          </div>

        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-dark shadow-sm">

          <div class="card-body">

            <p class="text-secondary">"Highly recommend them."</p>
            <strong class="text-warning">- Patient</strong>

          </div>

        </div>
      </div>

    </div>

  </div>

</section>

<section class="py-5 text-center bg-dark text-white">

  <div class="container">

    <h2 class="fw-bold text-warning">Ready for your new smile?</h2>

    <p class="text-light">Book your consultation today.</p>

   
    <%= link_to "Book Appointment", new_appointment_path, class: "btn btn-warning btn-lg fw-bold" %>
  </div>

</section>

<footer class="py-4 bg-black text-white text-center">

  <div class="container">
    <p class="mb-0">© <%= Date.today.year %> BrightSmile Dental Clinic</p>
  </div>

</footer>
