<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-8">

      <h2 class="mb-4 text-center">Book Your Appointment</h2>

      <%= form_with model: @appointment, class: "card p-4 shadow-sm" do |f| %>

        <% unless user_signed_in? %>
          <div class="mb-3">
            <%= f.label :name, "Full Name", class: "form-label" %>
            <%= f.text_field :name, class: "form-control", placeholder: "Enter your full name", required: true %>
          </div>

          <div class="mb-3">
            <%= f.label :email, "Email Address", class: "form-label" %>
            <%= f.email_field :email, class: "form-control", placeholder: "you@example.com", required: true %>
          </div>

          <div class="mb-3">
            <%= f.label :phone, "Phone Number", class: "form-label" %>
            <%= f.telephone_field :phone, class: "form-control", placeholder: "e.g. 07123 456789", required: true %>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.label :message, "Reason for Appointment", class: "form-label" %>
          <%= f.text_area :message, class: "form-control", rows: 4, placeholder: "Briefly describe your concern..." %>
        </div>

        <div class="mb-3 text-muted small text-center">
          A £20 deposit is required to secure your appointment. This amount will be deducted from your treatment cost during your visit.
        </div>

        <div class="d-grid">
          <%= f.submit "Continue to Payment (£20)",
              class: "btn btn-warning btn-lg",
              data: { disable_with: "Processing..." } %>
        </div>

      <% end %>

    </div>
  </div>
</div>
